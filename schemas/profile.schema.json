{
  "$defs": {
    "AdaptivePpbConfig": {
      "additionalProperties": false,
      "description": "Per-candidate extraction routing based on pixels-per-bit (PPB).\n\nCandidates with `ppb < threshold` run `low_extraction` + `low_refinement`;\ncandidates with `ppb >= threshold` run `high_extraction` + `high_refinement`.\nAt `ppb == threshold` exactly the low route wins (deterministic tie-break\nfor snapshot stability).",
      "properties": {
        "high_extraction": {
          "enum": [
            "ContourRdp",
            "EdLines"
          ],
          "title": "High Extraction",
          "type": "string"
        },
        "high_refinement": {
          "enum": [
            "Edge",
            "Erf",
            "Gwlf",
            "None"
          ],
          "title": "High Refinement",
          "type": "string"
        },
        "low_extraction": {
          "enum": [
            "ContourRdp",
            "EdLines"
          ],
          "title": "Low Extraction",
          "type": "string"
        },
        "low_refinement": {
          "enum": [
            "Edge",
            "Erf",
            "Gwlf",
            "None"
          ],
          "title": "Low Refinement",
          "type": "string"
        },
        "threshold": {
          "default": 2.5,
          "exclusiveMaximum": 5.0,
          "exclusiveMinimum": 1.0,
          "title": "Threshold",
          "type": "number"
        }
      },
      "title": "AdaptivePpbConfig",
      "type": "object"
    },
    "DecoderConfig": {
      "additionalProperties": false,
      "properties": {
        "decode_mode": {
          "enum": [
            "Hard",
            "Soft"
          ],
          "title": "Decode Mode",
          "type": "string"
        },
        "gwlf_transversal_alpha": {
          "default": 0.01,
          "minimum": 0.0,
          "title": "Gwlf Transversal Alpha",
          "type": "number"
        },
        "max_hamming_error": {
          "default": 2,
          "minimum": 0,
          "title": "Max Hamming Error",
          "type": "integer"
        },
        "min_contrast": {
          "default": 20.0,
          "minimum": 0.0,
          "title": "Min Contrast",
          "type": "number"
        },
        "refinement_mode": {
          "enum": [
            "Edge",
            "Erf",
            "Gwlf",
            "None"
          ],
          "title": "Refinement Mode",
          "type": "string"
        }
      },
      "title": "DecoderConfig",
      "type": "object"
    },
    "PoseConfig": {
      "additionalProperties": false,
      "properties": {
        "huber_delta_px": {
          "default": 1.5,
          "minimum": 0.0,
          "title": "Huber Delta Px",
          "type": "number"
        },
        "sigma_n_sq": {
          "default": 4.0,
          "minimum": 0.0,
          "title": "Sigma N Sq",
          "type": "number"
        },
        "structure_tensor_radius": {
          "default": 2,
          "maximum": 8,
          "minimum": 1,
          "title": "Structure Tensor Radius",
          "type": "integer"
        },
        "tikhonov_alpha_max": {
          "default": 0.25,
          "minimum": 0.0,
          "title": "Tikhonov Alpha Max",
          "type": "number"
        }
      },
      "title": "PoseConfig",
      "type": "object"
    },
    "QuadConfig": {
      "additionalProperties": false,
      "properties": {
        "extraction_mode": {
          "enum": [
            "ContourRdp",
            "EdLines"
          ],
          "title": "Extraction Mode",
          "type": "string"
        },
        "extraction_policy": {
          "anyOf": [
            {
              "const": "Static",
              "type": "string"
            },
            {
              "$ref": "#/$defs/_AdaptivePpbPolicy"
            }
          ],
          "default": "Static",
          "title": "Extraction Policy"
        },
        "max_aspect_ratio": {
          "default": 10.0,
          "minimum": 1.0,
          "title": "Max Aspect Ratio",
          "type": "number"
        },
        "max_elongation": {
          "default": 0.0,
          "minimum": 0.0,
          "title": "Max Elongation",
          "type": "number"
        },
        "max_fill_ratio": {
          "default": 0.98,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Max Fill Ratio",
          "type": "number"
        },
        "min_area": {
          "default": 16,
          "minimum": 1,
          "title": "Min Area",
          "type": "integer"
        },
        "min_density": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Min Density",
          "type": "number"
        },
        "min_edge_length": {
          "default": 4.0,
          "exclusiveMinimum": 0.0,
          "title": "Min Edge Length",
          "type": "number"
        },
        "min_edge_score": {
          "default": 4.0,
          "minimum": 0.0,
          "title": "Min Edge Score",
          "type": "number"
        },
        "min_fill_ratio": {
          "default": 0.1,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Min Fill Ratio",
          "type": "number"
        },
        "subpixel_refinement_sigma": {
          "default": 0.6,
          "minimum": 0.0,
          "title": "Subpixel Refinement Sigma",
          "type": "number"
        },
        "upscale_factor": {
          "default": 1,
          "minimum": 1,
          "title": "Upscale Factor",
          "type": "integer"
        }
      },
      "title": "QuadConfig",
      "type": "object"
    },
    "RescueConfig": {
      "additionalProperties": false,
      "description": "Second-chance decode for quads that pass the funnel but fail first-pass Hamming.\n\nMirrors `crates/locus-core/src/config.rs::RoiRescuePolicy`. When `enabled`\nis false (the default) the rescue stage is a single boolean branch in the\npipeline and all other fields here are inert.",
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "interpolation": {
          "enum": [
            "Bilinear",
            "Lanczos3"
          ],
          "title": "Interpolation",
          "type": "string"
        },
        "max_rescues_per_frame": {
          "default": 16,
          "maximum": 255,
          "minimum": 0,
          "title": "Max Rescues Per Frame",
          "type": "integer"
        },
        "max_roi_side_px": {
          "default": 128,
          "maximum": 65535,
          "minimum": 1,
          "title": "Max Roi Side Px",
          "type": "integer"
        },
        "require_first_pass_agreement": {
          "default": true,
          "title": "Require First Pass Agreement",
          "type": "boolean"
        },
        "rescue_max_hamming": {
          "default": 1,
          "maximum": 255,
          "minimum": 0,
          "title": "Rescue Max Hamming",
          "type": "integer"
        },
        "upscale_factor": {
          "default": 2,
          "title": "Upscale Factor",
          "type": "integer"
        }
      },
      "title": "RescueConfig",
      "type": "object"
    },
    "SegmentationConfig": {
      "additionalProperties": false,
      "properties": {
        "connectivity": {
          "enum": [
            "Eight",
            "Four"
          ],
          "title": "Connectivity",
          "type": "string"
        },
        "margin": {
          "default": 1,
          "title": "Margin",
          "type": "integer"
        }
      },
      "title": "SegmentationConfig",
      "type": "object"
    },
    "ThresholdConfig": {
      "additionalProperties": false,
      "properties": {
        "constant": {
          "default": 0,
          "title": "Constant",
          "type": "integer"
        },
        "enable_adaptive_window": {
          "default": false,
          "title": "Enable Adaptive Window",
          "type": "boolean"
        },
        "enable_sharpening": {
          "default": false,
          "title": "Enable Sharpening",
          "type": "boolean"
        },
        "gradient_threshold": {
          "default": 10,
          "maximum": 255,
          "minimum": 0,
          "title": "Gradient Threshold",
          "type": "integer"
        },
        "max_radius": {
          "default": 15,
          "minimum": 1,
          "title": "Max Radius",
          "type": "integer"
        },
        "min_radius": {
          "default": 2,
          "minimum": 1,
          "title": "Min Radius",
          "type": "integer"
        },
        "min_range": {
          "default": 10,
          "maximum": 255,
          "minimum": 0,
          "title": "Min Range",
          "type": "integer"
        },
        "tile_size": {
          "default": 8,
          "maximum": 64,
          "minimum": 2,
          "title": "Tile Size",
          "type": "integer"
        }
      },
      "title": "ThresholdConfig",
      "type": "object"
    },
    "_AdaptivePpbPolicy": {
      "additionalProperties": false,
      "description": "Wrapper mirroring serde's externally-tagged `{\"AdaptivePpb\": {...}}` form.",
      "properties": {
        "AdaptivePpb": {
          "$ref": "#/$defs/AdaptivePpbConfig"
        }
      },
      "required": [
        "AdaptivePpb"
      ],
      "title": "_AdaptivePpbPolicy",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Nested detector configuration \u2014 Python source of truth.\n\nThe three shipped profiles live in ``crates/locus-core/profiles/*.json``\nand are embedded into the Rust crate at compile time; the wheel reads\nthe exact same bytes through the FFI. Load via :meth:`from_profile`\nfor a shipped profile or :meth:`from_profile_json` for a user-supplied\nJSON string.",
  "properties": {
    "decoder": {
      "$ref": "#/$defs/DecoderConfig"
    },
    "extends": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extends"
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Name"
    },
    "pose": {
      "$ref": "#/$defs/PoseConfig"
    },
    "quad": {
      "$ref": "#/$defs/QuadConfig"
    },
    "rescue": {
      "$ref": "#/$defs/RescueConfig"
    },
    "segmentation": {
      "$ref": "#/$defs/SegmentationConfig"
    },
    "threshold": {
      "$ref": "#/$defs/ThresholdConfig"
    }
  },
  "title": "DetectorConfig",
  "type": "object"
}
